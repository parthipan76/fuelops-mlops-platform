{
  "uid": "fuelops-main",
  "title": "FuelOps MLOps Platform",
  "tags": ["fuelops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "panels": [
    {"id":1,"title":"API Status","type":"stat","gridPos":{"h":4,"w":4,"x":0,"y":0},"targets":[{"expr":"up{job=\"fuelops-api\"}","legendFormat":"Status","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}],"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"red","value":null},{"color":"green","value":1}]}}}},
    {"id":2,"title":"p95 Latency","type":"stat","gridPos":{"h":4,"w":4,"x":4,"y":0},"targets":[{"expr":"histogram_quantile(0.95, rate(request_latency_seconds_bucket[5m]))","legendFormat":"p95","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"unit":"s","color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":0.2},{"color":"red","value":0.5}]}}}},
    {"id":3,"title":"Request Rate","type":"stat","gridPos":{"h":4,"w":4,"x":8,"y":0},"targets":[{"expr":"sum(rate(prediction_count_total[5m]))","legendFormat":"RPS","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"unit":"reqps","color":{"mode":"fixed","fixedColor":"green"}}}},
    {"id":4,"title":"Total Predictions","type":"stat","gridPos":{"h":4,"w":4,"x":12,"y":0},"targets":[{"expr":"sum(prediction_count_total)","legendFormat":"Total","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"color":{"mode":"fixed","fixedColor":"blue"}}}},
    {"id":5,"title":"Total Errors","type":"stat","gridPos":{"h":4,"w":4,"x":16,"y":0},"targets":[{"expr":"sum(error_count_total) or vector(0)","legendFormat":"Errors","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"red","value":1}]}}}},
    {"id":6,"title":"Model Version","type":"stat","gridPos":{"h":4,"w":4,"x":20,"y":0},"targets":[{"expr":"model_info","legendFormat":"{{version}}","datasource":"Prometheus"}],"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},"fieldConfig":{"defaults":{"color":{"mode":"fixed","fixedColor":"purple"}}}},
    {"id":7,"title":"Latency Percentiles (p50 / p95 / p99)","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":4},"targets":[{"expr":"histogram_quantile(0.50, rate(request_latency_seconds_bucket[5m]))","legendFormat":"p50","datasource":"Prometheus"},{"expr":"histogram_quantile(0.95, rate(request_latency_seconds_bucket[5m]))","legendFormat":"p95","datasource":"Prometheus"},{"expr":"histogram_quantile(0.99, rate(request_latency_seconds_bucket[5m]))","legendFormat":"p99","datasource":"Prometheus"}],"fieldConfig":{"defaults":{"unit":"s","color":{"mode":"palette-classic"}}}},
    {"id":8,"title":"Predictions by Market and Fuel Type","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":4},"targets":[{"expr":"rate(prediction_count_total[5m])","legendFormat":"{{market}} - {{fuel_type}}","datasource":"Prometheus"}],"fieldConfig":{"defaults":{"unit":"reqps","color":{"mode":"palette-classic"}}}},
    {"id":9,"title":"Error Rate Over Time","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":12},"targets":[{"expr":"sum(rate(error_count_total[5m])) or vector(0)","legendFormat":"Error rate","datasource":"Prometheus"}],"fieldConfig":{"defaults":{"unit":"reqps","color":{"mode":"fixed","fixedColor":"red"}}}},
    {"id":10,"title":"Memory Usage (MB)","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":12},"targets":[{"expr":"process_resident_memory_bytes / 1024 / 1024","legendFormat":"RSS MB","datasource":"Prometheus"}],"fieldConfig":{"defaults":{"unit":"megbytes","color":{"mode":"fixed","fixedColor":"orange"}}}}
  ]
}